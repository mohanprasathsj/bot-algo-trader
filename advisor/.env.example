# ============================================================
#  Investment Advisor — API Key Configuration
#  Copy this file to .env and fill in your keys.
# ============================================================

# ----------------------------------------------------------
# 1. Google Gemini
#    Sign up: https://aistudio.google.com
#    Then: Get API Key
# ----------------------------------------------------------
GEMINI_API_KEY=AIza...

# ----------------------------------------------------------
# 2. Finnhub (news + sentiment)
#    Sign up: https://finnhub.io  →  Dashboard → API Key
#    Free tier: 60 calls/min, company news & sentiment included
# ----------------------------------------------------------
FINNHUB_API_KEY=your_finnhub_key_here

# ----------------------------------------------------------
# 3. Polygon.io (price / OHLCV data)
#    Sign up: https://polygon.io  →  Dashboard → API Keys
#    Free tier: unlimited calls, 15-min delayed data
#    Stocks Starter ($29/mo) gives real-time data
# ----------------------------------------------------------
POLYGON_API_KEY=your_polygon_key_here

# ----------------------------------------------------------
# 4. FRED (Federal Reserve macroeconomic data)
#    Register: https://fredaccount.stlouisfed.org/apikeys
#    Free, no usage limits for personal/research use
# ----------------------------------------------------------
FRED_API_KEY=your_fred_key_here
