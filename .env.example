# ============================================================
#  RoboAdvisor — API Key Configuration
#  Copy this file to .env and fill in your keys.
# ============================================================

# ----------------------------------------------------------
# 1. Google Gemini  (used by: advisor)
#    Sign up: https://aistudio.google.com  →  Get API Key
# ----------------------------------------------------------
GEMINI_API_KEY=AIza...

# ----------------------------------------------------------
# 2. Finnhub  (used by: advisor — news + sentiment)
#    Sign up: https://finnhub.io  →  Dashboard → API Key
#    Free tier: 60 calls/min
# ----------------------------------------------------------
FINNHUB_API_KEY=your_finnhub_key_here

# ----------------------------------------------------------
# 3. Polygon.io  (used by: advisor — price / OHLCV data)
#    Sign up: https://polygon.io  →  Dashboard → API Keys
#    Free tier: unlimited calls, 15-min delayed data
# ----------------------------------------------------------
POLYGON_API_KEY=your_polygon_key_here

# ----------------------------------------------------------
# 4. FRED  (used by: advisor — macroeconomic data)
#    Register: https://fredaccount.stlouisfed.org/apikeys
#    Free, no usage limits for personal/research use
# ----------------------------------------------------------
FRED_API_KEY=your_fred_key_here

# ----------------------------------------------------------
# 5. Interactive Brokers Gateway  (used by: investor live mode)
#    IB Gateway paper port: 4002  |  live port: 4001
#    TWS paper port:        7497  |  live port: 7496
#    Enable API access in IB Gateway: Configuration → API → Settings → Enable ActiveX and Socket Clients
# ----------------------------------------------------------
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_LIVE_PORT=4001
IBKR_CLIENT_ID=1

# investor module uses yfinance for historical data (no API key required)
